# ============================================================
# 三选一即可：填写任意一组 API Key，系统自动识别
# 优先级：OPENAI_API_KEY > DASHSCOPE_API_KEY > DEEPSEEK_API_KEY
# ============================================================

# 方案一：阿里云百炼 DashScope（推荐国内用户）
DASHSCOPE_API_KEY=sk-30d2b51d1bf94baeae45c6e48f6288d0
# 可选：开启深度思考（仅 DashScope）
# DASHSCOPE_ENABLE_THINKING=false

# 方案二：DeepSeek（OpenAI 兼容，性价比高）
# DEEPSEEK_API_KEY=sk-你的deepseek密钥
# 默认使用 deepseek-chat 模型，也可通过 OPENAI_MODEL 覆盖

# 方案三：OpenAI / 其他 OpenAI 兼容服务
# OPENAI_API_KEY=sk-请替换为你的真实key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 通用：手动指定模型（不设则自动选择）
# OPENAI_MODEL=gpt-4o-mini
