{
  "version": "broad-heuristic-2.0-style",
  "description": "教学用广覆盖启发式规则：按 ICD-10 章/段推断 MDC，手术码前缀+兜底；非国家医保局正式发布稿，不用于实际结算",
  "mdc_rules": [
    {
      "id": "mdc-b-neuro",
      "match_principal_icd": ["^A01\\.002\\+G01", "^A01\\.002"],
      "mdc_code": "MDCB",
      "mdc_name": "神经系统疾病及功能障碍"
    },
    {
      "id": "mdc-i-msk-hip",
      "match_principal_icd": ["^S72\\.0"],
      "mdc_code": "MDCI",
      "mdc_name": "骨骼、肌肉、结缔组织疾病及功能障碍"
    },
    {
      "id": "mdc-i-msk-fracture-more",
